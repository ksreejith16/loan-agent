# =====================================================
# N CARE HOSPITAL — Backend environment variables
# Copy this to `.env` and fill in real values.
# =====================================================

# ----- Server -----
PORT=4000
NODE_ENV=development
# Allow your frontend origin (comma-separated for multiple)
CORS_ORIGINS=http://localhost:5173,https://ncarehospital.com

# ----- JWT -----
# Generate a strong random string (e.g. `openssl rand -hex 64`)
JWT_SECRET=replace-me-with-a-strong-random-secret

# ----- Database (MongoDB) -----
# If unset, server runs in IN-MEMORY mode (data lost on restart) — fine for testing.
# For production, use MongoDB Atlas or self-hosted MongoDB.
# Example: MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/ncare?retryWrites=true&w=majority
MONGODB_URI=

# ----- SMS / OTP (Twilio) -----
# If unset, OTP is logged to the server console (dev mode).
# Get free credentials at https://www.twilio.com/try-twilio (or use MSG91 for India).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=        # e.g. +1xxxxxxxxxx

# ----- Email (Nodemailer SMTP) -----
# Used to email confirmations to the hospital + patient.
# If unset, email is logged to the server console.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="N Care Hospital <noreply@ncarehospital.com>"
HOSPITAL_NOTIFICATION_EMAIL=appointments@ncarehospital.com

# ----- Chatbot (Gemini) -----
# Get a free key at https://aistudio.google.com/apikey
# When unset, the chatbot scripted flows still work; only free-text Q&A is stubbed.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Hospital phone used in chatbot replies (e.g. emergency intercept).
HOSPITAL_PHONE=+91 40 6162 6364

# ----- Rate limiting -----
OTP_MAX_PER_HOUR=5
CHAT_MAX_PER_MINUTE=20
